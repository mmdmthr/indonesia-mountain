---
import fs from "node:fs";
import path from "node:path";

import MainLayout from "../../layouts/MainLayout.astro";

import MountainViewer from "../../components/MountainViewer.jsx";

export async function getStaticPaths() {
    const dir = path.join(process.cwd(), "public/heightmaps");

    const files = fs.readdirSync(dir);

    return files
        .filter((file) => file.endsWith("_heightmap.png"))
        .map((file) => ({
            params: {
                slug: file.replace("_heightmap.png", ""),
            },
        }));
}

const { slug } = Astro.params;
---

<MainLayout fullWidth={true}>
    <MountainViewer
        client:only
        slug={slug}
        bbox={{
            north: -7.339934,
            south: -7.439919,
            west: 110.009976,
            east: 110.129988,
        }}
    />
</MainLayout>
