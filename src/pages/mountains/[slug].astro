---
import fs from "node:fs";
import path from "node:path";

import type { GetStaticPaths } from "astro";
import MainLayout from "../../layouts/MainLayout.astro";
import MountainViewer from "../../components/MountainViewer.jsx";
import type { Mountain } from "../../api/mountains";
import { getAllMountains } from "../../api/mountains";

// Explicitly mark as statically pre-rendered (important when using Netlify SSR adapter)
export const prerender = true;

export const getStaticPaths: GetStaticPaths = async () => {
    // Single query — all 315+ mountains with full data fetched once.
    // The result is module-level cached in api/mountains.ts, so any other
    // build-time code that also calls getAllMountains() pays zero extra cost.
    let mountains: Mountain[] = [];
    try {
        mountains = await getAllMountains();
    } catch (err) {
        console.warn("[mountains/[slug]] Could not fetch mountains from Supabase:", err);
    }

    // Build a lookup map for fast O(1) access when merging heightmap-only slugs
    const mountainBySlug = new Map(mountains.map((m) => [m.slug, m]));

    // Also include slugs from heightmap files so 3D-only pages still build
    const heightmapDir = path.join(process.cwd(), "public/heightmaps");
    try {
        const files = fs.readdirSync(heightmapDir) as string[];
        files
            .filter((file: string) => file.endsWith("_heightmap.png"))
            .map((file: string) => file.replace("_heightmap.png", ""))
            .filter((s: string) => !mountainBySlug.has(s))
            .forEach((s: string) => mountainBySlug.set(s, null as unknown as Mountain));
    } catch {
        // heightmaps dir may be empty or missing
    }

    // Each path carries its mountain data as props — no per-page DB query needed
    return [...mountainBySlug.entries()].map(([slug, mountain]) => ({
        params: { slug },
        props: { mountain },
    }));
};

const { slug } = Astro.params;
const { mountain } = Astro.props as { mountain: Mountain | null };

if (!mountain) {
    return Astro.redirect("/404");
}

// Check if a heightmap exists for the 3D viewer
const heightmapPath = path.join(
    process.cwd(),
    "public/heightmaps",
    `${slug}_heightmap.png`,
);
const hasHeightmap = fs.existsSync(heightmapPath);

const provinceName = mountain.provinces?.name ?? "Tidak diketahui";
const elevationFormatted = mountain.elevation.toLocaleString("id-ID");

// SEO metadata
const pageTitle = `${mountain.name} (${elevationFormatted} mdpl) – Gunung Nusantara`;
const pageDescription = `${mountain.name} adalah gunung dengan ketinggian ${elevationFormatted} mdpl yang terletak di ${provinceName}.`;

const canonicalURL = Astro.site
    ? `${Astro.site}mountains/${slug}`
    : Astro.url.href;

// Build bbox from Supabase data when available, otherwise fall back to a default
const hasBbox =
    mountain.min_lat != null &&
    mountain.min_lng != null &&
    mountain.max_lat != null &&
    mountain.max_lng != null;

const bbox = hasBbox
    ? {
          north: mountain.max_lat!,
          south: mountain.min_lat!,
          west: mountain.min_lng!,
          east: mountain.max_lng!,
      }
    : {
          north: -7.339934,
          south: -7.439919,
          west: 110.009976,
          east: 110.129988,
      };
---

<MainLayout
    title={pageTitle}
    description={pageDescription}
    canonicalURL={canonicalURL}
>
    <!-- Basic information – always visible -->
    <div class="max-w-2xl mx-auto py-8 px-4">
        <!-- Back link -->
        <a
            href="/"
            class="inline-block mb-6 text-sm text-teal-600 dark:text-teal-400 hover:underline"
        >
            ← Kembali ke daftar gunung
        </a>

        <!-- Mountain name -->
        <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-1">
            {mountain.name}
        </h1>

        <!-- Province -->
        <p class="text-teal-700 dark:text-teal-400 font-medium mb-6">
            {provinceName}
        </p>

        <!-- Stats grid -->
        <dl class="grid grid-cols-2 gap-4 mb-8 bg-teal-700 dark:bg-teal-800 rounded-xl px-6 py-4 text-yellow-100">
            <div>
                <dt class="text-xs uppercase tracking-wide text-teal-300 mb-1">
                    Ketinggian
                </dt>
                <dd class="text-xl font-semibold">
                    {elevationFormatted}{" "}
                    <span class="text-sm font-normal">mdpl</span>
                </dd>
            </div>
            <div>
                <dt class="text-xs uppercase tracking-wide text-teal-300 mb-1">
                    Koordinat
                </dt>
                <dd class="text-sm font-mono">
                    {mountain.lat.toFixed(5)}, {mountain.lng.toFixed(5)}
                </dd>
            </div>
        </dl>

        <!-- Google Maps link -->
        <a
            href={`https://www.google.com/maps/@${mountain.lat},${mountain.lng},13z`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-teal-600 dark:text-teal-400 hover:underline"
        >
            📍 Lihat di Google Maps
        </a>
    </div>

    <!-- 3D viewer – only rendered when a heightmap is available -->
    {
        hasHeightmap && (
            <div class="w-full" style="height: 60vh;">
                <MountainViewer client:only slug={slug} bbox={bbox} />
            </div>
        )
    }
</MainLayout>
